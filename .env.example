# Akeyless authentication (access key is the most common method)
AKEYLESS_ACCESS_ID=p-xxxxx
AKEYLESS_ACCESS_KEY=your-access-key
AKEYLESS_ACCESS_TYPE=access_key

# Single Gateway URL — SDK API and ARA base are derived automatically
AKEYLESS_GATEWAY_URL=https://your-gateway.example.com:8000/api/v2

# Agent identifier for ARA session auditing
AKEYLESS_AGENT_ID=claude-desktop

# Optional default secret path for query-db (same as CLI --secret-name)
# AKEYLESS_DEFAULT_SECRET_NAME=/demo/apps/analytics/postgres-ro

# SAML / OIDC — set access type and access id; browser opens on first tool call
# AKEYLESS_ACCESS_TYPE=saml
# AKEYLESS_ACCESS_ID=p-xxxxx

# Universal Identity — token is read from file on each auth refresh (supports auto-rotation)
# AKEYLESS_ACCESS_TYPE=universal_identity
# AKEYLESS_UID_TOKEN_FILE=${HOME}/.akeyless/uid_rotator/uid-token

# JWT
# AKEYLESS_ACCESS_TYPE=jwt
# AKEYLESS_ACCESS_ID=p-xxxxx
# AKEYLESS_JWT=your-jwt

# Cloud IAM
# AKEYLESS_ACCESS_TYPE=aws_iam
# AKEYLESS_ACCESS_ID=p-xxxxx
